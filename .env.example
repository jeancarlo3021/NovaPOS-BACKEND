# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# CORS — frontend URL(s), separados por coma si hay varios
# Ejemplo desarrollo: http://localhost:5173
# Ejemplo producción: https://novapos.vercel.app
FRONTEND_URL=http://localhost:5173

# Puerto local (solo desarrollo)
PORT=3001

# ─── Resend (envío de correos) ──────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=ColónClick <no-reply@colonclick.com>

# ─── Facturemos CR (Facturación Electrónica) ────────────────────────────────
# Clave MAESTRA del cliente (Genius Technology). Secreta — solo backend.
# Se usa en /api/Token/ObtenerToken para autenticar.
FACTUREMOS_API_KEY_CLIENTE=

# ─── Alanube (Facturación Electrónica — proveedor alternativo) ───────────────
# Token Bearer (JWT) de tu cuenta Alanube. Secreto — solo backend.
ALANUBE_ENV=sandbox
ALANUBE_API_TOKEN=
ALANUBE_BASE_URL=
